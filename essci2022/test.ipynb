   "source": [
    "from csv import DictReader\n",
    "\n",
    "with open('data/combustdb_master.csv', 'r') as csv_file:\n",
    "    reader = DictReader(csv_file)\n",
    "    rows = [r for r in reader]\n",
    "csv_file.close()\n",
    "\n",
    "compounds = [r for r in rows if r['properties.cetane_number.value'] != '-']\n",
    "print(len(compounds))"
   ]
